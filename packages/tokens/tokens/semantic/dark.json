{
  "color": {
    "bg": {
      "default": { "$value": "{color.slate.950}", "$type": "color" },
      "subtle": { "$value": "{color.slate.900}", "$type": "color" },
      "muted": { "$value": "{color.slate.800}", "$type": "color" },
