      "inverse": { "$value": "{color.slate.50}", "$type": "color" }
    },
    "fg": {
      "default": { "$value": "{color.slate.50}", "$type": "color" },
      "muted": { "$value": "{color.slate.400}", "$type": "color" },
      "subtle": { "$value": "{color.slate.500}", "$type": "color" },
      "onEmphasis": { "$value": "{color.slate.900}", "$type": "color" },
      "onAccent": { "$value": "{color.white}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.slate.700}", "$type": "color" },
