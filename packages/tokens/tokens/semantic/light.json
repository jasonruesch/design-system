{
  "color": {
    "bg": {
      "default": { "$value": "{color.white}", "$type": "color" },
      "subtle": { "$value": "{color.slate.50}", "$type": "color" },
      "muted": { "$value": "{color.slate.100}", "$type": "color" },
      "emphasis": { "$value": "{color.slate.900}", "$type": "color" },
      "inverse": { "$value": "{color.slate.900}", "$type": "color" }
    },
    "fg": {
      "default": { "$value": "{color.slate.900}", "$type": "color" },
      "muted": { "$value": "{color.slate.600}", "$type": "color" },
      "subtle": { "$value": "{color.slate.500}", "$type": "color" },
      "onEmphasis": { "$value": "{color.white}", "$type": "color" },
      "onAccent": { "$value": "{color.white}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.slate.200}", "$type": "color" },
      "muted": { "$value": "{color.slate.100}", "$type": "color" },
      "strong": { "$value": "{color.slate.300}", "$type": "color" }
    },
    "accent": {
      "default": { "$value": "{color.blue.600}", "$type": "color" },
      "hover": { "$value": "{color.blue.700}", "$type": "color" },
      "active": { "$value": "{color.blue.800}", "$type": "color" },
      "subtle": { "$value": "{color.blue.50}", "$type": "color" },
      "fg": { "$value": "{color.blue.700}", "$type": "color" }
    },
    "success": {
      "default": { "$value": "{color.green.600}", "$type": "color" },
      "fg": { "$value": "{color.green.700}", "$type": "color" },
      "subtle": { "$value": "{color.green.50}", "$type": "color" },
      "border": { "$value": "{color.green.200}", "$type": "color" }
    },
    "warning": {
      "default": { "$value": "{color.amber.500}", "$type": "color" },
      "fg": { "$value": "{color.amber.700}", "$type": "color" },
      "subtle": { "$value": "{color.amber.50}", "$type": "color" },
      "border": { "$value": "{color.amber.200}", "$type": "color" }
    },
    "danger": {
      "default": { "$value": "{color.red.600}", "$type": "color" },
      "hover": { "$value": "{color.red.700}", "$type": "color" },
      "fg": { "$value": "{color.red.700}", "$type": "color" },
      "subtle": { "$value": "{color.red.50}", "$type": "color" },
      "border": { "$value": "{color.red.200}", "$type": "color" }
    },
    "focus": {
      "ring": { "$value": "{color.blue.600}", "$type": "color" }
    }
  }
}
