{
  "name": "design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "tokens:build": "turbo run tokens:build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.9.18",
    "typescript": "^5.7.3"
  }
}
